# Denku — example environment variables
#
# This file documents the EMAIL / Resend configuration (R-080). It is NOT the full
# env inventory — see `skills/deployment-and-environments.md` for the complete list
# (Supabase, Vapi, Stripe, etc.). Copy relevant values into `.env.local` (gitignored)
# or set them in Vercel. Never commit real secrets.

# --- Resend (email) ---
# API key for Resend. Emails are skipped (no-op) when this is unset.
RESEND_API_KEY=

# Sender ("From") addresses — centralized in src/lib/email/senders.ts (R-080).
# All senders MUST use the VERIFIED denku.io domain. The legacy sandbox
# `onboarding@resend.dev` is removed (it could only deliver to the account owner).
#
# Resolution order per stream: RESEND_FROM_<STREAM> -> RESEND_FROM -> built-in default.
# Leave these unset to use the verified-domain defaults shown below.

# Global fallback sender for every stream (optional).
RESEND_FROM="Denku <no-reply@denku.io>"

# Per-stream overrides (optional). Defaults are used when unset:
#   auth    -> Denku <no-reply@denku.io>      (verification / OTP / password-reset)
#   notify  -> Denku <notifications@denku.io> (artifact notifications, digests)
#   welcome -> Denku <hello@denku.io>         (welcome + human-reply-friendly)
RESEND_FROM_AUTH="Denku <no-reply@denku.io>"
RESEND_FROM_NOTIFY="Denku <notifications@denku.io>"
RESEND_FROM_WELCOME="Denku <hello@denku.io>"

# --- Artifact notifications (R-008) ---
# Staged rollout gate. Enable ONLY after the migration is applied, the Vapi webhook
# is in enforce mode (VAPI_WEBHOOK_AUTH_MODE=enforce), and denku.io deliverability
# is confirmed. Any value other than "true" keeps notifications OFF.
ARTIFACT_NOTIFICATIONS_ENABLED=

# --- Platform model dual-writes (Sprint 4.5) ---
# Master switch for writing Voice + Instagram into the shared conversation model
# (conversations/messages/contacts). Default OFF → legacy behavior is byte-for-byte
# unchanged. Enable ONLY after the four 20260724* platform migrations are applied
# (see docs/SPRINT_4.5_MIGRATION.md). Any value other than "true" keeps dual-writes OFF.
PLATFORM_MODEL_ENABLED=

# --- Platform experience / IA (Sprint 5) ---
# Dark-launch switch for the AI Employees experience (Employees · Conversations · Contacts
# · Channels nav + surfaces). Default OFF → the current voice-first dashboard is served
# unchanged. Independent of PLATFORM_MODEL_ENABLED — the new surfaces read via the Platform
# Read Model over existing data. Any value other than "true" keeps the classic UI.
PLATFORM_UX_ENABLED=
